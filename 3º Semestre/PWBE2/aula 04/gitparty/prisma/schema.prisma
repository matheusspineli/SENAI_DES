// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuarios {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  senha         String
  data_cadastro DateTime @default(now())

  inscricoes Inscricoes[]
}

model Eventos {
  id                Int           @id @default(autoincrement())
  titulo            String
  descricao         String
  data_evento       DateTime
  local             String
  capacidade_maxima Int
  status            StatusEventos @default(ATIVO)
  data_criacao      DateTime      @default(now())

  inscricoes Inscricoes[]
  imagens    Imagem[]
}

model Inscricoes {
  id             Int             @id @default(autoincrement())
  data_inscricao DateTime        @default(now())
  status         StatusInscricao @default(CONFIRMADA)

  evento   Eventos @relation(fields: [eventoId], references: [id])
  eventoId Int

  usuario   Usuarios @relation(fields: [usuarioId], references: [id])
  usuarioId Int

  @@unique([eventoId, usuarioId]) 
}

model Imagem {
  id           Int      @id @default(autoincrement())
  nomeOriginal String   
  nomeArquivo  String   
  mimeType     String   
  path         String   
  tamanho      Int?    
  data_upload  DateTime @default(now())

  evento   Eventos @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  eventoId Int
}

enum StatusInscricao {
  CONFIRMADA
  LISTA_ESPERA
  CANCELADA
}

enum StatusEventos {
  ATIVO
  CANCELADO
  ENCERRADO
}
